# macOS
.DS_Store

# Local env (never commit secrets)
.env
.env.local
.env.*.local

# Editor
.vscode/
.idea/

# Build artefacts (none yet, but reserve)
dist/
build/

# Node
node_modules/

# Vite
.vite/
dist-ssr/
*.local

# Logs / coverage
*.log
coverage/
.nyc_output/

# TypeScript incremental build cache
*.tsbuildinfo

# Generated outputs from `tsc -b` against tsconfig.node.json
# (source of truth is vite.config.ts)
vite.config.js
vite.config.d.ts

# Claude Code session metadata (local-only)
.claude/

# Supabase CLI workspace (caches, runtime artefacts)
supabase/.temp/
supabase/.branches/
