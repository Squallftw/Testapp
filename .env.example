# BatiTrack — environment variables
#
# Copy this file to .env.local (gitignored) and fill in real values from
# your Supabase project: Settings → API.
#
# Vite refuses to expose env vars without the VITE_ prefix to client code,
# as a guardrail against leaking secrets. Do NOT rename these.
#
# The anon key is safe to ship to the client — RLS enforces access. Never
# put the service_role key here; it bypasses RLS and is server-only.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
